{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/terms-of-service",
      "destination": "/terms-of-service.html"
    },
    {
      "source": "/gdpr-compliance",
      "destination": "/gdpr-compliance.html"
    },
    {
      "source": "/legal-notice",
      "destination": "/legal-notice.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/status",
      "destination": "/status.html"
    }
  ],
  "redirects": [
    {
      "source": "/betterlife",
      "destination": "https://betterlife.care/",
      "permanent": false
    },
    {
      "source": "/agentforge",
      "destination": "https://agentforge-beta-three.vercel.app/",
      "permanent": false
    },
    {
      "source": "/helix",
      "destination": "https://vane.sytes.net/",
      "permanent": false
    },
    {
      "source": "/seo-api",
      "destination": "https://seo-api-nu.vercel.app/",
      "permanent": false
    }
  ]
}
